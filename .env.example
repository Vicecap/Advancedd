APP_BASE_URL=https://ts.totalsportss.online
DOCUMENTS_BASE_URL=https://doc.totalsportss.online
CORS_ORIGINS=https://ts.totalsportss.online,https://doc.totalsportss.online
SECURITY_LOG_PATH=/var/log/zimsolve/security.log
REDIS_URL=
SESSION_SECRET=change-me
ADMIN_INIT_TOKEN=
DATABASE_URL=postgres://user:password@host:5432/db

# AI / OCR (backend only)
AGENT_BASE=https://ts.totalsportss.online
AI_PROVIDER=openrouter
AI_TIMEOUT_MS=60000
AI_ALLOWED_MODELS=mistralai/mistral-7b-instruct,qwen/qwen-2.5-7b-instruct,google/gemini-2.0-flash-001,google/gemini-flash-1.5-8b
OPENROUTER_API_KEY=
AI_INTEGRATIONS_OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=mistralai/mistral-7b-instruct
OPENAI_API_KEY=
GEMINI_API_KEY=
OCR_TIMEOUT_MS=20000

# DiscHub
DISCHUB_API_BASE_URL=https://dischub.co.zw
DISCHUB_API_KEY=
DISCHUB_RECIPIENT_EMAIL=
DISCHUB_MODE=test
DISCHUB_CALLBACK_URL=https://ts.totalsportss.online/api/billing/dischub/callback
DISCHUB_REDIRECT_URL=https://ts.totalsportss.online/payment/status
DISCHUB_SUCCESS_URL=https://ts.totalsportss.online/payment/status?provider=dischub&status=success
DISCHUB_CANCEL_URL=https://ts.totalsportss.online/payment/status?provider=dischub&status=cancelled

# PayPal live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=live
PAYPAL_WEBHOOK_ID=
PAYPAL_SUCCESS_URL=https://ts.totalsportss.online/payment/status?provider=paypal&status=success
PAYPAL_CANCEL_URL=https://ts.totalsportss.online/payment/status?provider=paypal&status=cancelled

# Manual payments
ECOCASH_ENABLED=false
ECOCASH_NUMBER=
ECOCASH_INSTRUCTIONS=
ECOCASH_DIASPORA_ENABLED=false
ECOCASH_DIASPORA_NUMBER=
ECOCASH_DIASPORA_INSTRUCTIONS=
BANK_ENABLED=false
BANK_DETAILS=
BANK_INSTRUCTIONS=

# Object storage
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=/objects
DEFAULT_OBJECT_ACL=private
GOOGLE_APPLICATION_CREDENTIALS=
GCS_BUCKET=

# External fetch / SSRF protection
ALLOWED_EXTERNAL_HOSTS=doc.totalsportss.online
EXTERNAL_FETCH_TIMEOUT_MS=10000
EXTERNAL_FETCH_MAX_BYTES=25000000

# Token/package limits
AUTH_WEEKLY_TOKEN_ALLOWANCE=60000
GUEST_WEEKLY_TOKEN_ALLOWANCE=20000
CUSTOM_TOKEN_MIN=100000
